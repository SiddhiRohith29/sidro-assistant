# Optional OpenAI API key. Leave blank when using Ollama/local mode.
OPENAI_API_KEY=

# Chat provider: auto, openai, or ollama.
SIDRO_CHAT_PROVIDER=ollama
OPENAI_CHAT_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_NUM_PREDICT=1000
OLLAMA_NUM_CTX=4096

# Speech-to-text. Current local setup uses faster-whisper in English mode.
SIDRO_STT_PROVIDER=faster_whisper
FASTER_WHISPER_MODEL=tiny
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

# Text-to-speech. OpenAI needs OPENAI_API_KEY. Piper can be configured locally later.
SIDRO_TTS_PROVIDER=auto
PIPER_EXE=
PIPER_MODEL=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy

# Frontend URL allowed by the backend CORS policy.
SIDRO_ALLOWED_ORIGIN=http://127.0.0.1:5180
